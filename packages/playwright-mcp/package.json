{
  "name": "@enyonee/playwright-mcp-ultra",
  "version": "0.1.1",
  "description": "Playwright MCP Ultra - fork with ~60x token optimization for AI agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enyonee/playwright-mcp-ultra.git"
  },
  "homepage": "https://github.com/enyonee/playwright-mcp-ultra",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Microsoft Corporation"
  },
  "license": "Apache-2.0",
  "mcpName": "io.github.microsoft/playwright-mcp",
  "scripts": {
    "lint": "node update-readme.js",
    "test": "playwright test",
    "ctest": "playwright test --project=chrome",
    "ftest": "playwright test --project=firefox",
    "wtest": "playwright test --project=webkit",
    "dtest": "MCP_IN_DOCKER=1 playwright test --project=chromium-docker",
    "build": "echo OK",
    "npm-publish": "npm run lint && npm run test && npm publish"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index-optimized.js"
    }
  },
  "dependencies": {
    "playwright": "1.60.0-alpha-1775258971000",
    "playwright-core": "1.60.0-alpha-1775258971000"
  },
  "bin": {
    "playwright-mcp": "cli-optimized.js"
  }
}
